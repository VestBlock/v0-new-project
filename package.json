    "buyers:kimi-outreach": "node scripts/kimi-buyer-outreach-pipeline.mjs",
    "buyers:kimi-send-preview": "node --env-file=.env.local scripts/send-buyer-criteria-drafts.mjs --limit=25 --daily-cap=50",
