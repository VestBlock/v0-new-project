{
  "name": "my-v0-project",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "next build",
    "check:app": "npm run typecheck && npm run build",
    "check:contracts": "npm run compile:contracts && npm run test:contracts",
    "check:dealvault:deploy:base": "hardhat run scripts/checkDealVaultDeployReadiness.ts --network base",
    "check:dealvault:deploy:base-sepolia": "hardhat run scripts/checkDealVaultDeployReadiness.ts --network baseSepolia",
    "check:dealvault:deploy:polygon": "hardhat run scripts/checkDealVaultDeployReadiness.ts --network polygon",
    "check:dealvault:deploy:amoy": "hardhat run scripts/checkDealVaultDeployReadiness.ts --network amoy",
    "compile:contracts": "hardhat compile",
    "copy-abis": "ts-node scripts/copyAbis.ts",
    "clean:local": "rm -rf .next tsconfig.tsbuildinfo automation-run-results.json artifacts cache",
    "demo:dealvault": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/createDealVaultDemoPackage.ts",
    "dev": "next dev",
    "deploy:dealvault:amoy": "hardhat run scripts/deployDealVault.ts --network amoy",
    "deploy:dealvault:base": "hardhat run scripts/deployDealVault.ts --network base",
    "deploy:dealvault:base-sepolia": "hardhat run scripts/deployDealVault.ts --network baseSepolia",
    "deploy:dealvault:polygon": "hardhat run scripts/deployDealVault.ts --network polygon",
    "estimate:dealvault:proof:polygon": "hardhat run scripts/estimateDealVaultProofGas.ts --network polygon",
    "live-test:dealvault:proof:polygon": "hardhat run scripts/liveTestDealVaultProof.ts --network polygon",
    "lint": "eslint .",
    "smoke:dealvault:base-sepolia": "hardhat run scripts/smokeDealVault.ts --network baseSepolia",
    "start": "next start",
    "test:contracts": "hardhat test",
    "test:smoke": "playwright test tests/smoke",
    "typecheck": "tsc --noEmit",
    "check:release": "npm run check:app && npm run check:contracts",
    "verify:dealvault:ui": "node --env-file=.env.local scripts/verifyDealVaultUiFlow.mjs",
    "outreach:scorecard": "npm run outreach:v4-scorecard",
    "outreach:preflight": "npm run outreach:v4-scorecard",
    "outreach:review": "npm run outreach:v4-approve -- --limit=50",
    "outreach:approve-safe": "npm run outreach:v4-approve -- --limit=50",
    "process:gmail-bounces": "node --env-file=.env.local scripts/process-gmail-bounces.mjs",
    "suppress:bad-lead-emails": "node --env-file=.env.local scripts/suppress-bad-lead-emails.mjs",
    "outreach:export:no-email": "node --env-file=.env.local scripts/export-manual-no-email-leads.mjs",
    "revenue:command": "node --env-file=.env.local scripts/revenue-command-scorecard.mjs",
    "aeo:daily-audit": "node --env-file=.env.local -e \"const headers=process.env.CRON_SECRET?{authorization:'Bearer '+process.env.CRON_SECRET}:{};fetch('http://localhost:3001/api/cron/aeo-site-audit?dryRun=true',{headers}).then(r=>r.json()).then(d=>console.log(JSON.stringify(d,null,2)))\"",
    "visibility:aeo-scorecard": "node scripts/visibility-aeo-scorecard.mjs",
    "visibility:proof-assets": "node scripts/captureVisibilityProofAssets.mjs",
    "visibility:indexing-push": "node --env-file=.env.local scripts/visibility-indexing-push.mjs",
    "visibility:indexing-dry-run": "node --env-file=.env.local scripts/visibility-indexing-push.mjs --dry-run",
    "buffer:facebook-calendar": "node scripts/buffer-facebook-content-calendar.mjs",
    "buffer:facebook-schedule": "node --env-file=.env.local scripts/buffer-facebook-content-calendar.mjs --send --max=6",
    "relationships:landbank-reo": "node --env-file=.env.local scripts/landbank-reo-relationship-campaign.mjs",
    "relationships:landbank-reo:send": "node --env-file=.env.local scripts/landbank-reo-relationship-campaign.mjs --send",
    "outreach:quarantine-export": "node --env-file=.env.local scripts/export-outreach-quarantine.mjs",
    "outreach:quarantine-export:apply": "node --env-file=.env.local scripts/export-outreach-quarantine.mjs --apply",
    "outreach:v4-dry-run": "node --env-file=.env.local scripts/outreach-v4-dry-run.mjs",
    "outreach:v4-scorecard": "node --env-file=.env.local scripts/outreach-v4-scorecard.mjs",
    "outreach:v4-approve": "node --env-file=.env.local scripts/outreach-v4-approve-drafts.mjs",
    "outreach:v4-workflow": "node --env-file=.env.local scripts/outreach-v4-workflow.mjs",
    "outreach:daily-expand": "node --env-file=.env.local scripts/offline-daily-outreach-orchestrator.mjs",
