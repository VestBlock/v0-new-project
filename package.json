    "investors:discover": "node --env-file=.env.local -e \"const headers=process.env.CRON_SECRET?{authorization:'Bearer '+process.env.CRON_SECRET}:{};fetch('http://localhost:3001/api/cron/investors-discover',{headers}).then(r=>r.json()).then(d=>console.log(JSON.stringify(d,null,2)))\"",
    "investors:pipeline:dry-run": "node --env-file=.env.local -e \"const headers=process.env.CRON_SECRET?{authorization:'Bearer '+process.env.CRON_SECRET}:{};fetch('http://localhost:3001/api/cron/investors-pipeline?dryRun=true',{headers}).then(r=>r.json()).then(d=>console.log(JSON.stringify(d,null,2)))\"",
    "investors:send:dry-run": "node --env-file=.env.local -e \"const headers=process.env.CRON_SECRET?{authorization:'Bearer '+process.env.CRON_SECRET}:{};fetch('http://localhost:3001/api/cron/investors-send?dryRun=true',{headers}).then(r=>r.json()).then(d=>console.log(JSON.stringify(d,null,2)))\"",
    "outreach:v4-send-approved": "node --env-file=.env.local scripts/outreach-v4-send-approved.mjs",
    "outreach:v4-send-approved:live": "node --env-file=.env.local scripts/outreach-v4-send-approved.mjs --send",
    "leads:small-business": "node --env-file=.env.local scripts/offline-small-business-lead-builder.mjs",
    "leads:latino-funding": "node --env-file=.env.local scripts/offline-small-business-lead-builder.mjs --verticals=spanish_funding --markets=\"Chicago, IL|Milwaukee, WI|Houston, TX|Dallas, TX|Phoenix, AZ|Los Angeles, CA|San Antonio, TX|Miami, FL\" --queries-per-vertical=6 --per-query=4 --website-limit=48",
    "distress:stack": "node scripts/distress-stack-builder.mjs --market=cincinnati --areas=2",
    "distress:stack:daily": "zsh scripts/distress-stack-daily.sh",
    "distress:stack:install": "zsh scripts/install-distress-stack-agent.sh",
    "distress:skiptrace-prep": "node scripts/skip-trace-prep.mjs",
    "boss:stale-listings": "node --env-file=.env.local scripts/stale-listing-finder.mjs",
    "distress:dealmachine:ingest-export": "node scripts/dealmachine-ingest-export.mjs",
    "distress:dealmachine:ingest-export:apply": "node scripts/dealmachine-ingest-export.mjs --apply",
    "distress:dealmachine:research-checklists": "node --env-file=.env.local scripts/dealmachine-research-checklists.mjs",
    "distress:clean-csv": "node scripts/export-clean-distress-stack-csv.mjs",
    "distress:dealmachine": "node scripts/dealmachine-push.mjs",
    "distress:dealmachine:import": "node scripts/dealmachine-push.mjs",
    "distress:dealmachine:push25": "node --env-file=.env.local scripts/dealmachine-push.mjs --push --limit=25",
    "distress:dealmachine:push100": "node --env-file=.env.local scripts/dealmachine-push.mjs --push --limit=100",
    "distress:dealmachine:market-harvest": "node --env-file=.env.local scripts/dealmachine-market-harvest.mjs",
    "distress:dealmachine:market-harvest:stacks": "node --env-file=.env.local scripts/dealmachine-market-harvest.mjs --top-markets=5 --contactable-only --stacked",
    "distress:dealmachine:export-outreach": "node --env-file=.env.local scripts/dealmachine-export-outreach.mjs",
    "distress:dealmachine:owner-email": "node --env-file=.env.local scripts/dealmachine-owner-email.mjs --limit=100",
    "distress:dealmachine:owner-email:address-pass": "node --env-file=.env.local scripts/dealmachine-owner-email.mjs --limit=100 --address-pass",
    "distress:dealmachine:owner-email:send": "node --env-file=.env.local scripts/dealmachine-owner-email.mjs --limit=100 --send",
    "distress:dealmachine:owner-email:address-pass:send": "node --env-file=.env.local scripts/dealmachine-owner-email.mjs --limit=100 --address-pass --send",
    "distress:dealmachine:push": "node --env-file=.env.local scripts/dealmachine-push.mjs --push",
    "distress:dealmachine:pull": "node --env-file=.env.local scripts/dealmachine-push.mjs --pull"
  },
